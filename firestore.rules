rules_version = '2';

// Reglas de seguridad de Firestore para MypiCuadre (Fase 4 - Bloque 26).
//
// Modelo: una cuenta de Firebase por NEGOCIO; el uid de esa cuenta ES el
// businessId. Todos los datos cuelgan de /businesses/{businessId}. Solo quien
// inicio sesion con esa cuenta (auth.uid == businessId) puede leer/escribir.
// Nada se borra (append-only): la app corrige con ajustes, nunca con delete.
service cloud.firestore {
  match /databases/{database}/documents {

    match /businesses/{businessId} {
      allow read: if isOwner(businessId);
      // Solo se puede crear/actualizar el propio negocio.
      allow create, update: if isOwner(businessId);
      allow delete: if false;

      // Todo el arbol de datos del negocio (ventas, productos, turnos, etc.).
      match /{document=**} {
        allow read: if isOwner(businessId);
        allow create, update: if isOwner(businessId);
        allow delete: if false; // append-only: nada se borra
      }
    }

    function isOwner(businessId) {
      return request.auth != null && request.auth.uid == businessId;
    }
  }
}
